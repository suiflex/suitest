{
  "openapi": "3.0.3",
  "info": {
    "title": "httpbin (synthetic subset, CC0)",
    "version": "1.0.0"
  },
  "servers": [{ "url": "https://httpbin.example" }],
  "paths": {
    "/get": {
      "get": {
        "operationId": "httpGet",
        "tags": ["http"],
        "responses": {
          "200": {
            "description": "echoes request",
            "content": {
              "application/json": {
                "schema": { "type": "object", "properties": { "url": { "type": "string" } } }
              }
            }
          }
        }
      }
    },
    "/post": {
      "post": {
        "operationId": "httpPost",
        "tags": ["http"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["message"],
                "properties": { "message": { "type": "string", "minLength": 1, "maxLength": 20 } }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "echoes body",
            "content": {
              "application/json": {
                "schema": { "type": "object", "properties": { "json": { "type": "object" } } }
              }
            }
          }
        }
      }
    },
    "/status/{code}": {
      "get": {
        "operationId": "httpStatus",
        "tags": ["http"],
        "parameters": [
          {
            "name": "code",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "minimum": 100, "maximum": 599 }
          }
        ],
        "responses": {
          "200": { "description": "returns the requested status" }
        }
      }
    }
  }
}
