{
  "suite": "Brewly — generated from PRD.md",
  "description": "Generated by AI from PRD.md (R1–R6). Committed as a fixture so the demo replays at ZERO tier; add an LLM key to generate your own.",
  "cases": [
    {
      "name": "Menu lists all launch items with stock (R1)",
      "source": "AI",
      "priority": "P1",
      "status": "ACTIVE",
      "target_kind": "BE_REST",
      "mcp_provider": "api-mcp",
      "description": "PRD R1: fixed launch menu of 4 items, each with price and stock.",
      "steps": [
        {
          "order": 0,
          "action": "Reset Brewly to seed state",
          "expected": "State reset accepted (204)",
          "code": {
            "tool": "http.request",
            "arguments": {"method": "POST", "url": "${DEMO_APP_URL}/api/reset"},
            "assertions": [
              {"tool": "http.assert_status", "arguments": {"equals": 204}}
            ]
          }
        },
        {
          "order": 1,
          "action": "GET /api/menu",
          "expected": "200 with 4 items; Espresso first at $3.00 with stock 10",
          "code": {
            "tool": "http.request",
            "arguments": {"method": "GET", "url": "${DEMO_APP_URL}/api/menu"},
            "assertions": [
              {"tool": "http.assert_status", "arguments": {"equals": 200}},
              {"tool": "http.assert_json_path", "arguments": {"path": "$[0].name", "equals": "Espresso"}},
              {"tool": "http.assert_json_path", "arguments": {"path": "$[0].price", "equals": 3.0}},
              {"tool": "http.assert_json_path", "arguments": {"path": "$[0].stock", "equals": 10}},
              {"tool": "http.assert_json_path", "arguments": {"path": "$[3].name", "equals": "Matcha Latte"}}
            ]
          }
        }
      ]
    },
    {
      "name": "Placing an order reserves stock (R2)",
      "source": "AI",
      "priority": "P0",
      "status": "ACTIVE",
      "target_kind": "BE_REST",
      "mcp_provider": "api-mcp",
      "description": "PRD R2: order returns id + total (price × qty) and immediately decrements stock.",
      "steps": [
        {
          "order": 0,
          "action": "Reset Brewly to seed state",
          "expected": "State reset accepted (204)",
          "code": {
            "tool": "http.request",
            "arguments": {"method": "POST", "url": "${DEMO_APP_URL}/api/reset"},
            "assertions": [
              {"tool": "http.assert_status", "arguments": {"equals": 204}}
            ]
          }
        },
        {
          "order": 1,
          "action": "POST /api/orders — 2× Espresso",
          "expected": "201 with total 6.00 and status pending",
          "code": {
            "tool": "http.request",
            "arguments": {
              "method": "POST",
              "url": "${DEMO_APP_URL}/api/orders",
              "json": {"item_id": 1, "quantity": 2}
            },
            "assertions": [
              {"tool": "http.assert_status", "arguments": {"equals": 201}},
              {"tool": "http.assert_json_path", "arguments": {"path": "$.total", "equals": 6.0}},
              {"tool": "http.assert_json_path", "arguments": {"path": "$.status", "equals": "pending"}}
            ]
          }
        },
        {
          "order": 2,
          "action": "GET /api/menu — Espresso stock after order",
          "expected": "Espresso stock decremented from 10 to 8",
          "code": {
            "tool": "http.request",
            "arguments": {"method": "GET", "url": "${DEMO_APP_URL}/api/menu"},
            "assertions": [
              {"tool": "http.assert_json_path", "arguments": {"path": "$[0].stock", "equals": 8}}
            ]
          }
        }
      ]
    },
    {
      "name": "Order beyond stock is rejected (R3)",
      "source": "AI",
      "priority": "P0",
      "status": "ACTIVE",
      "target_kind": "BE_REST",
      "mcp_provider": "api-mcp",
      "description": "PRD R3: quantity above current stock → 409 'insufficient stock', stock unchanged.",
      "steps": [
        {
          "order": 0,
          "action": "Reset Brewly to seed state",
          "expected": "State reset accepted (204)",
          "code": {
            "tool": "http.request",
            "arguments": {"method": "POST", "url": "${DEMO_APP_URL}/api/reset"},
            "assertions": [
              {"tool": "http.assert_status", "arguments": {"equals": 204}}
            ]
          }
        },
        {
          "order": 1,
          "action": "POST /api/orders — 99× Cold Brew (stock 10)",
          "expected": "409 conflict with detail 'insufficient stock'",
          "code": {
            "tool": "http.request",
            "arguments": {
              "method": "POST",
              "url": "${DEMO_APP_URL}/api/orders",
              "json": {"item_id": 3, "quantity": 99}
            },
            "assertions": [
              {"tool": "http.assert_status", "arguments": {"equals": 409}},
              {"tool": "http.assert_json_path", "arguments": {"path": "$.detail", "equals": "insufficient stock"}}
            ]
          }
        },
        {
          "order": 2,
          "action": "GET /api/menu — Cold Brew stock unchanged",
          "expected": "Cold Brew stock still 10",
          "code": {
            "tool": "http.request",
            "arguments": {"method": "GET", "url": "${DEMO_APP_URL}/api/menu"},
            "assertions": [
              {"tool": "http.assert_json_path", "arguments": {"path": "$[2].stock", "equals": 10}}
            ]
          }
        }
      ]
    },
    {
      "name": "Checkout applies 10% bulk discount (R4, R5)",
      "source": "AI",
      "priority": "P1",
      "status": "ACTIVE",
      "target_kind": "BE_REST",
      "mcp_provider": "api-mcp",
      "description": "PRD R4+R5: orders of ≥4 units get 10% off at checkout; checkout marks order paid.",
      "steps": [
        {
          "order": 0,
          "action": "Reset Brewly to seed state",
          "expected": "State reset accepted (204)",
          "code": {
            "tool": "http.request",
            "arguments": {"method": "POST", "url": "${DEMO_APP_URL}/api/reset"},
            "assertions": [
              {"tool": "http.assert_status", "arguments": {"equals": 204}}
            ]
          }
        },
        {
          "order": 1,
          "action": "POST /api/orders — 5× Latte",
          "expected": "201 with pre-discount total 22.50",
          "code": {
            "tool": "http.request",
            "arguments": {
              "method": "POST",
              "url": "${DEMO_APP_URL}/api/orders",
              "json": {"item_id": 2, "quantity": 5}
            },
            "assertions": [
              {"tool": "http.assert_status", "arguments": {"equals": 201}},
              {"tool": "http.assert_json_path", "arguments": {"path": "$.total", "equals": 22.5}}
            ]
          }
        },
        {
          "order": 2,
          "action": "POST /api/orders/1/checkout",
          "expected": "200 paid with discounted total 20.25 (10% off)",
          "code": {
            "tool": "http.request",
            "arguments": {"method": "POST", "url": "${DEMO_APP_URL}/api/orders/1/checkout"},
            "assertions": [
              {"tool": "http.assert_status", "arguments": {"equals": 200}},
              {"tool": "http.assert_json_path", "arguments": {"path": "$.status", "equals": "paid"}},
              {"tool": "http.assert_json_path", "arguments": {"path": "$.total", "equals": 20.25}}
            ]
          }
        },
        {
          "order": 3,
          "action": "GET /api/orders/1 — lookup after payment (R6)",
          "expected": "Order retrievable with status paid",
          "code": {
            "tool": "http.request",
            "arguments": {"method": "GET", "url": "${DEMO_APP_URL}/api/orders/1"},
            "assertions": [
              {"tool": "http.assert_status", "arguments": {"equals": 200}},
              {"tool": "http.assert_json_path", "arguments": {"path": "$.status", "equals": "paid"}}
            ]
          }
        }
      ]
    },
    {
      "name": "Storefront shows menu and brand (R1, UI)",
      "source": "AI",
      "priority": "P2",
      "status": "ACTIVE",
      "target_kind": "FE_WEB",
      "mcp_provider": "playwright-mcp",
      "description": "PRD Interfaces: web storefront at / renders brand header and live menu.",
      "steps": [
        {
          "order": 0,
          "action": "Open the Brewly storefront",
          "expected": "Page loads with 'Brewly' brand header",
          "code": {
            "tool": "browser_navigate",
            "arguments": {"url": "${DEMO_APP_URL}/"},
            "assertions": [
              {"tool": "browser.assert_text", "arguments": {"contains": "Brewly"}}
            ]
          }
        },
        {
          "order": 1,
          "action": "Wait for the menu grid to load",
          "expected": "Espresso card visible in the menu",
          "code": {
            "tool": "browser_wait_for",
            "arguments": {"text": "Espresso"}
          }
        },
        {
          "order": 2,
          "action": "Capture storefront screenshot",
          "expected": "Screenshot artifact attached to the run",
          "code": {
            "tool": "browser_take_screenshot",
            "arguments": {}
          }
        }
      ]
    }
  ]
}
