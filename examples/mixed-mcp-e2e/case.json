{
  "name": "Add-to-cart across DB + API + browser",
  "targetKind": "FE_WEB",
  "steps": [
    {"order": 1, "action": "Seed product", "expected": "1 row inserted", "mcpProvider": "postgres-mcp", "targetKind": "DATA", "code": "INSERT INTO products(id,name,price) VALUES('p1','Widget',9.99)"},
    {"order": 2, "action": "Add to cart via API", "expected": "201 Created", "mcpProvider": "api-http-mcp", "targetKind": "BE_REST", "code": "POST /cart {\"productId\":\"p1\"}"},
    {"order": 3, "action": "Verify in browser", "expected": "Widget visible in cart", "mcpProvider": "playwright-mcp", "targetKind": "FE_WEB", "code": "await page.goto('/cart'); await expect(page.getByText('Widget')).toBeVisible()"},
    {"order": 4, "action": "Verify cart row", "expected": "cart_items has 1 row", "mcpProvider": "postgres-mcp", "targetKind": "DATA", "code": "SELECT count(*) FROM cart_items WHERE product_id='p1'"}
  ]
}
