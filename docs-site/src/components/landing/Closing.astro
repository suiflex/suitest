---
import arrowIcon from "@phosphor-icons/core/assets/regular/arrow-right.svg?raw";
import bookIcon from "@phosphor-icons/core/assets/regular/book-open.svg?raw";

const year = new Date().getFullYear();

// Product Hunt launch badge (official embed markup — kept verbatim, self-contained inline styles).
const productHuntBadge = `<div style="font-family: -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, Roboto, &quot;Helvetica Neue&quot;, Arial, sans-serif; border: 1px solid rgb(224, 224, 224); border-radius: 12px; padding: 20px; max-width: 500px; background: rgb(255, 255, 255); box-shadow: rgba(0, 0, 0, 0.05) 0px 2px 8px;"><div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;"><img alt="Suitest" src="https://ph-files.imgix.net/db5194df-355f-4728-8d3c-bc73d46f109e.svg?auto=compress,format&amp;codec=mozjpeg&amp;cs=strip&amp;fit=crop&amp;h=80&amp;w=80" style="width: 64px; height: 64px; border-radius: 8px; object-fit: cover; flex-shrink: 0;"><div style="flex: 1 1 0%; min-width: 0px;"><h3 style="margin: 0px; font-size: 18px; font-weight: 600; color: rgb(26, 26, 26); line-height: 1.3; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">Suitest</h3><p style="margin: 4px 0px 0px; font-size: 14px; color: rgb(102, 102, 102); line-height: 1.4; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">Free E2E AI testing &amp; MCP server. A TestSprite alternative.</p></div></div><a href="https://www.producthunt.com/products/suitest?embed=true&amp;utm_source=embed&amp;utm_medium=post_embed" target="_blank" rel="noopener" style="display: inline-flex; align-items: center; gap: 4px; margin-top: 12px; padding: 8px 16px; background: rgb(255, 97, 84); color: rgb(255, 255, 255); text-decoration: none; border-radius: 8px; font-size: 14px; font-weight: 600;">Check it out on Product Hunt →</a></div>`;

const footCols = [
  {
    title: "Product",
    links: [
      { label: "Features", href: "/#features" },
      { label: "MCP tools", href: "/#mcp-tools" },
      { label: "Deployment", href: "/#deploy" },
      { label: "CI Action", href: "/#ci" },
      { label: "Comparison", href: "/#compare" },
    ],
  },
  {
    title: "Documentation",
    links: [
      { label: "Getting started", href: "/docs/guides/getting-started/" },
      { label: "Install the MCP server", href: "/docs/install/mcp-server/" },
      { label: "Agent workflow", href: "/docs/guides/agent-workflow/" },
      { label: "CLI reference", href: "/docs/reference/cli/" },
      { label: "Self-hosting", href: "/docs/guides/self-hosting/" },
      { label: "Troubleshooting", href: "/docs/help/troubleshooting/" },
    ],
  },
  {
    title: "Project",
    links: [
      { label: "GitHub", href: "https://github.com/suiflex/suitest", ext: true },
      { label: "Roadmap", href: "https://github.com/suiflex/suitest/blob/main/docs/ROADMAP.md", ext: true },
      { label: "Contributing", href: "https://github.com/suiflex/suitest/blob/main/CONTRIBUTING.md", ext: true },
      { label: "Changelog", href: "https://github.com/suiflex/suitest/blob/main/CHANGELOG.md", ext: true },
      { label: "Security policy", href: "https://github.com/suiflex/suitest/blob/main/SECURITY.md", ext: true },
      { label: "License (Apache-2.0)", href: "https://github.com/suiflex/suitest/blob/main/LICENSE", ext: true },
    ],
  },
];
---

<section class="section closing">
  <div class="wrap closing-inner" data-reveal>
    <h2 class="closing-title">Apache-2.0 licensed.<br />No cloud required.</h2>
    <p class="closing-sub">
      Your stack, your LLM, your data. Run the whole platform on a laptop or a
      cluster.
    </p>
    <div class="closing-ctas">
      <a href="/docs/guides/getting-started/" class="btn btn-primary">
        Get started
        <Fragment set:html={arrowIcon} />
      </a>
      <a href="/docs/" class="btn btn-ghost">
        <Fragment set:html={bookIcon} />
        Read the docs
      </a>
    </div>
  </div>
</section>

<footer class="foot">
  <div class="wrap">
    <div class="foot-grid">
      <div class="foot-brand-col">
        <div class="foot-brand">
          <svg viewBox="0 0 32 32" aria-hidden="true" class="foot-mark">
            <rect width="32" height="32" rx="7" fill="#161719"></rect>
            <rect x="8" y="9.5" width="16" height="3.4" rx="1.7" fill="#4ade80"></rect>
            <rect x="8" y="16.4" width="7.5" height="3.4" rx="1.7" fill="#4ade80" opacity=".55"></rect>
            <path d="M18.6 18.9l2.6 2.6 4.6-5.4" fill="none" stroke="#4ade80" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          <span>Suitest</span>
        </div>
        <p class="foot-tag">
          Open-source, MCP-native testing platform. Manual test management,
          deterministic runs, optional AI.
        </p>
        <div class="ph-badge" set:html={productHuntBadge} />
      </div>

      {
        footCols.map((col) => (
          <nav class="foot-col" aria-label={col.title}>
            <h3>{col.title}</h3>
            <ul>
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    target={link.ext ? "_blank" : undefined}
                    rel={link.ext ? "noopener" : undefined}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <p class="foot-copy">Copyright {year} Suitest contributors. Apache-2.0 License.</p>
  </div>
</footer>

<style>
  .closing {
    text-align: center;
    padding-block: 140px;
  }
  .closing-title {
    font-size: clamp(34px, 5vw, 56px);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.06;
    margin: 0 0 18px;
  }
  .closing-sub {
    color: var(--text-2);
    font-size: 17px;
    max-width: 46ch;
    margin: 0 auto 36px;
  }
  .closing-ctas {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .foot {
    border-top: 1px solid var(--border);
    padding-block: 56px 40px;
  }
  .foot-grid {
    display: grid;
    grid-template-columns: minmax(0, 5fr) repeat(3, minmax(0, 3fr));
    gap: 40px;
    margin-bottom: 44px;
  }
  .foot-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    margin-bottom: 14px;
  }
  .foot-mark {
    width: 26px;
    height: 26px;
  }
  .foot-tag {
    margin: 0;
    font-size: 13.5px;
    line-height: 1.65;
    color: var(--text-3);
    max-width: 34ch;
  }
  .ph-badge {
    margin-top: 20px;
  }
  .foot-col h3 {
    margin: 0 0 14px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
  }
  .foot-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .foot-col a {
    font-size: 13.5px;
    color: var(--text-2);
    transition: color 0.2s;
  }
  .foot-col a:hover {
    color: var(--text);
  }
  .foot-copy {
    margin: 0;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    font-size: 13px;
    color: var(--text-3);
  }

  @media (max-width: 900px) {
    .closing {
      padding-block: 96px;
    }
    .foot-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
    .foot-brand-col {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 540px) {
    .foot-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
