# === Default seed accounts (created by `make seed`) ===
# Login after seeding. All three share password: admin123
#   maya@nusantararetail.local   (OWNER)
#   ari@nusantararetail.local    (ADMIN)
#   dimas@nusantararetail.local  (QA)

# === Required ===
POSTGRES_PASSWORD=suitest
SUITEST_AUTH_SECRET=replace-with-32-char-random-hex
SUITEST_ENCRYPTION_KEY=replace-with-base64-32-byte-key

# === Super-admin bootstrap (first-install login, ZERO tier needs no LLM) ===
# Created idempotently on API startup if no users exist yet. Then invite others
# by link from Settings (onboarding is invite-only). Leave blank to skip bootstrap.
SUITEST_SUPERADMIN_EMAIL=
SUITEST_SUPERADMIN_PASSWORD=
SUITEST_SUPERADMIN_WORKSPACE_NAME=Default Workspace

# === Database / queue / storage ===
SUITEST_DATABASE_URL=postgresql+asyncpg://suitest:suitest@postgres:5432/suitest
SUITEST_REDIS_URL=redis://redis:6379/0
SUITEST_S3_ENDPOINT=http://minio:9000
SUITEST_S3_BUCKET=suitest-artifacts
SUITEST_S3_ACCESS_KEY=minioadmin
SUITEST_S3_SECRET_KEY=minioadmin

# === Runner concurrency & MCP pool tuning ===
# Number of ARQ jobs the runner executes in parallel per worker process.
SUITEST_RUNNER_CONCURRENCY=4
# Per-job ARQ retry budget (transient failures before the job is marked failed).
SUITEST_RUNNER_MAX_RETRIES=2
# Hard wall-clock budget for a single run_test_case job (seconds).
SUITEST_RUNNER_JOB_TIMEOUT_SECONDS=1800
# Per-workspace cap on concurrent MCP sessions (across all providers).
SUITEST_MCP_MAX_SESSIONS_PER_WORKSPACE=16
# How long an MCP acquire() may wait for a free slot before raising MCP_POOL_EXHAUSTED.
SUITEST_MCP_QUEUE_TIMEOUT_SECONDS=30

# === URLs ===
SUITEST_WEB_URL=http://localhost:3000
SUITEST_API_URL=http://localhost:4000

# === LLM / tier ===
# Configured per-workspace from the web UI (Settings → LLM provider), not via env.
# Default tier is ZERO (no LLM). Set a provider in the app to unlock AI features.

# === OAuth (optional, required for login flow in Task 7) ===
SUITEST_OAUTH_GOOGLE_CLIENT_ID=
SUITEST_OAUTH_GOOGLE_CLIENT_SECRET=

# === Session cookie security ===
# Set to true in production behind HTTPS so the session cookie is only sent over TLS.
SUITEST_COOKIE_SECURE=false

# === Local mode (no PostgreSQL + no S3) ===
# Run Suitest against a local SQLite file and a plain disk folder for artifacts.
# Create the schema first: python -c "import asyncio; from suitest_db.bootstrap import create_local_schema; from suitest_db.engine import make_engine; asyncio.run(create_local_schema(make_engine()))"
# SUITEST_DATABASE_URL=sqlite+aiosqlite:///.suitest/suitest.db
# SUITEST_ARTIFACTS_BACKEND=local        # default: s3
# SUITEST_ARTIFACTS_DIR=.suitest/artifacts
